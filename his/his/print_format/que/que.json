 "html": "<main class=\"scp mx\">\r\n    <header style=\"display: flex; align-items: center; gap: 50px; border-bottom: 2px solid black;\" class=\"mx\">\r\n        <div>\r\n           {{ letter_head }}\r\n        </div>\r\n    </header>\r\n    \r\n        <!---->\r\n<section style=\"display: flex; justify-content: space-between;  border-bottom: 2px solid black;\" class=\"mx\">\r\n    <div style=\"display: flex; justify-content: flex-start; align-items: center;\">\r\n        <span style=\"font-size: 20px; font-weight: bold;\">Print Date:</span>\r\n        <span style=\"font-size: 18px; white-space: nowrap;\">{{ frappe.utils.nowdate() }}</span>\r\n    </div>\r\n    \r\n    <div style=\"display: flex; justify-content: flex-start; align-items: center;\">\r\n        <span style=\"font-size: 20px; font-weight: bold;\">Issue Date:</span>\r\n        <span style=\"font-size: 18px; white-space: nowrap;\">{{ doc.date }}</span>\r\n    </div>\r\n</section>\r\n        <!---->\r\n    \r\n        <section style=\" border-top: 0px solid black; display: flex; gap: 0; justify-content: space-between; flex-wrap: wrap; padding: 0;\" class=\"mx\">\r\n                      \r\n\r\n    \r\n    <div style=\"display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0; margin-top: 10px;\">\r\n\r\n\r\n<div style=\"display: flex; margin-top: 0px\" class=\"mx\">\r\n\r\n        <div style=\"display: flex; justify-content: flex-start; align-items: center;\">\r\n        <span style=\"font-size: 20px; font-weight: bold;\">Ref No:</span>\r\n        <span style=\"font-size: 18px; white-space: nowrap;\">{{ doc.name }}</span>\r\n    </div>\r\n    \r\n        <div style=\"display: flex; justify-content: flex-end; width: 100%; margin-top: 00px; flex: 1\">\r\n  <div>\r\n        <img \r\n            src=\"https://api.qrserver.com/v1/create-qr-code/?size=60x60&data={{ doc.patient }} {{ doc.patient_name }}\" \r\n            alt=\"QR Code\"\r\n            style=\"width:60px; height:60px;\"\r\n        >\r\n    </div>\r\n</div>\r\n    \r\n    \r\n</div>\r\n\r\n    \r\n    \r\n    \r\n</div>\r\n\r\n    \r\n\r\n    \r\n\r\n    \r\n\r\n        </section>\r\n        \r\n        <section style=\"display: flex; gap: 0; justify-content: center; border-top: 1px solid black; padding: 10px 0\">\r\n             <div style=\" border: 2px solid black; width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center;\">\r\n        <span style=\"font-size: 24px; font-weight: bold; text-align: center;\">{{doc.token_no}}</span>\r\n    </div>    \r\n        </section>\r\n\r\n        <section style=\" border-top: 1px solid black;  border-bottom: 1px solid black; display: flex; justify-content: space-between; padding: 0px; font-size: 14px\" class=\"mx\">\r\n<div style=\"display: flex; flex-direction: column; gap: 10px; margin-top: 10px;\">\r\n    <div class=\"pse\" style=\"display: flex; justify-content: flex-start; align-items: center; flex: 1;\">\r\n        <span style=\"font-size: 20px; font-weight: bold; width: 120px;\">Patient ID:</span> \r\n        <span style=\"font-size: 18px; white-space: nowrap;\">{{ doc.patient }}</span>\r\n    </div>\r\n    <div class=\"pse\" style=\"display: flex; justify-content: flex-start; align-items: center; flex: 1; padding-bottom: 10px;\">\r\n        <span style=\"font-size: 20px; font-weight: bold; width: 120px;\"> Name:</span> \r\n        <span style=\"font-size: 18px; white-space: nowrap;\">{{ doc.patient_name }}</span>\r\n    </div>\r\n</div>\r\n\r\n    </section>\r\n\r\n\r\n    <section style=\" border-bottom: 1px solid black; display: flex; justify-content: space-between; padding: 0px; font-size: 14px\" class=\"mx\">\r\n      <div style=\"display: flex; flex-direction: column; gap: 10px; margin-top: 10px;\">\r\n    <div class=\"pse\" style=\"display: flex; justify-content: flex-start; align-items: center;\">\r\n        <span style=\"font-size: 20px; font-weight: bold; width: 120px;\">Doctor:</span>\r\n        <span style=\"font-size: 18px; white-space: nowrap;\">{{ doc.practitioner }}</span>\r\n    </div>\r\n    \r\n    <div class=\"pse\" style=\"display: flex; justify-content: flex-start; align-items: center;\">\r\n        <span style=\"font-size: 20px; font-weight: bold; width: 120px;\">Department:</span>\r\n        <span style=\"font-size: 18px; white-space: nowrap;\">{{ doc.department }}</span>\r\n    </div>\r\n    \r\n    <div class=\"pse\" style=\"display: flex; justify-content: flex-start; align-items: center;\">\r\n        <span style=\"font-size: 20px; font-weight: bold; width: 120px;\">Service:</span>\r\n        <span style=\"font-size: 18px; white-space: nowrap;\">Consultant</span>\r\n    </div>\r\n    \r\n      <div class=\"pse\" style=\"display: flex; justify-content: flex-start; align-items: center;\">\r\n        <span style=\"font-size: 20px; font-weight: bold; width: 120px;\">Type:</span>\r\n        <span style=\"font-size: 18px; white-space: nowrap;\">{{doc.que_type }}</span>\r\n    </div>\r\n    <!-- Follow-up text -->\r\n    <span style=\"font-size: 18px; font-weight: bold;\">\r\n        \r\n    </span>\r\n</div>\r\n\r\n    </section>\r\n    \r\n\r\n    <section style=\"display: flex; justify-content: center; margin-top: 20px; padding: 0 20px;\" class=\"mx\">\r\n    \r\n    <div style=\"border-top: 1px solid black; width: 300px; margin-top: 18px\">\r\n    <div style=\"display: flex; flex-direction: column; gap: 0;\">\r\n        <div class=\"item\" style=\"display: flex; justify-content: space-between; border-bottom: 1px solid black\">\r\n            <strong style=\"font-size: 20px\">Amount:</strong>\r\n            <span style=\"font-size: 18px\">{% if doc.is_free or doc.follow_up %} $0.00 {% else %} ${{ doc.doctor_amount }}.00 {% endif %}</span>\r\n        </div>\r\n        <div class=\"item\" style=\"display: flex; justify-content: space-between; border-bottom: 1px solid black\">\r\n            <strong style=\"font-size: 20px\">Discount:</strong>\r\n            <span style=\"font-size: 18px\">{% if doc.is_free or doc.follow_up %} $0.00 {% else %} ${{doc.discount }}.00 {% endif %}</span>\r\n        </div>\r\n        <!--<div class=\"item\" style=\"display: flex; justify-content: space-between; border-bottom: 1px solid black\">-->\r\n        <!--    <strong style=\"font-size: 20px\">Tax(5%):</strong>-->\r\n        <!--    <span style=\"font-size: 18px\">{% if doc.is_free or doc.follow_up %} $0 {% else %} {{ 0.05 * doc.paid_amount }} {% endif %}</span>-->\r\n        <!--</div>-->\r\n        <div class=\"item\" style=\"display: flex; justify-content: space-between;\">\r\n            <strong style=\"font-size: 20px\">Total:</strong>\r\n                         <div style=\"display: flex; flex-direction: column\">\r\n                            <span style=\"font-size: 18px\">{% if doc.is_free or doc.follow_up %} $0.00 {% else %}   ${{ \"%.2f\"|format(doc.paid_amount) }}  {% endif %}</span>\r\n                      <div  style=\"display: flex; flex-direction: column\">\r\n                        <div style=\"border-bottom: 1px solid black; width: 50px;  height: 3px;\"></div>  \r\n                        <div style=\"border-bottom: 1px solid black; width: 50px;  height: 3px;\"></div>  \r\n                      </div>\r\n                              </div>\r\n        </div>\r\n        </div>\r\n     \r\n    </div>\r\n\r\n    </section>\r\n\r\n    <footer style=\"display: flex; flex-direction: column; gap: 20px; align-items: center; justify-content: center; padding: 0 20px; font-size: 12px; margin-top: 10px\" class=\"mx\">\r\n        <span class=\"span\">{{frappe.db.get_value(\"User\" , doc.owner , \"full_name\")}}</span>\r\n    </footer>\r\n</main>",
