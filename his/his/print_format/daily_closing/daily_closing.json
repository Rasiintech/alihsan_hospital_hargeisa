 "font_size": 14,
 "html": "<style>\r\n  .pf-wrap { font-family: Arial, sans-serif; font-size: 11px; color:#111; }\r\n  .pf-header { display:flex; justify-content:space-between; align-items:flex-start; border-bottom:2px solid #111; padding-bottom:8px; margin-bottom:10px; }\r\n  .pf-title { font-size:18px; font-weight:700; margin:0; }\r\n  .pf-sub { margin:2px 0 0 0; color:#444; font-size:11px; }\r\n  .meta { text-align:right; font-size:11px; }\r\n  .meta b { display:inline-block; min-width:95px; }\r\n  .section-title {\r\n      margin:14px 0 6px;\r\n      font-weight:700;\r\n      font-size:12px;\r\n      padding:6px 8px;\r\n      background:#f2f2f2;\r\n      border:1px solid #000;\r\n    }\r\n  table { width:100%; border-collapse:collapse; margin-top:6px; border:1px solid #000; }\r\n  th, td { border:1px solid #000; padding:6px 8px; vertical-align:top; }\r\n  th { background:#fafafa; font-weight:700; text-align:left; }\r\n  .num { text-align:right; white-space:nowrap; }\r\n  .totals { margin-top:8px; display:flex; justify-content:flex-end; }\r\n  .totals table { width:320px; }\r\n  .totals td { border:1px solid #000; }\r\n  .note { margin-top:10px; padding:8px; border:1px dashed #bbb; min-height:40px; }\r\n  .sign { margin-top:18px; display:flex; gap:20px; }\r\n  .sign .box { flex:1; border-top:1px solid #111; padding-top:6px; font-size:11px; }\r\n  .small { font-size:10px; color:#555; margin-top:10px; }\r\n</style>\r\n <section style=\"width: 700px; margin: 0 auto;\">\r\n<div class=\"pf-wrap\">\r\n {{ letter_head }}\r\n  <div class=\"pf-header\">\r\n     \r\n    <div>\r\n      <p class=\"pf-title\">Daily Closing</p>\r\n      <p class=\"pf-sub\">\r\n \r\n      </p>\r\n    </div>\r\n\r\n    <div class=\"meta\">\r\n      <div><b>No:</b> {{ doc.name }}</div>\r\n      <div><b>Date:</b> {{ doc.date or \"\" }}</div>\r\n      <div><b>User:</b> {{ doc.user_name or \"\" }}</div>\r\n    </div>\r\n  </div>\r\n\r\n  <div class=\"section-title\">Daily Cash - USD Accounts</div>\r\n  <table>\r\n    <thead>\r\n      <tr>\r\n        <th style=\"width:50px; color:black\">No.</th>\r\n        <th style=\"color:black\">USD Account</th>\r\n        <th class=\"num\" style=\"width:140px; color:black\">Amount (USD)</th>\r\n      </tr>\r\n    </thead>\r\n    <tbody>\r\n      {% set usd_total = 0 %}\r\n      {% if doc.accounts %}\r\n        {% for r in doc.accounts %}\r\n          {% set usd_total = usd_total + (r.amount or 0) %}\r\n          <tr>\r\n            <td>{{ loop.index }}</td>\r\n            <td>{{ r.account or \"\" }}</td>\r\n            <td class=\"num\">{{ frappe.format_value(r.amount or 0, {\"fieldtype\":\"Currency\", \"options\":\"USD\"}) }}</td>\r\n          </tr>\r\n        {% endfor %}\r\n      {% else %}\r\n        <tr><td colspan=\"3\" style=\"text-align:center;color:#777;\">No USD rows</td></tr>\r\n      {% endif %}\r\n    </tbody>\r\n  </table>\r\n\r\n  <div class=\"section-title\">Daily Cash - Shilling Accounts</div>\r\n  <table>\r\n    <thead>\r\n      <tr>\r\n        <th style=\"width:50px; color:black\">No.</th>\r\n        <th style=\"color:black\">Shilling Account</th>\r\n        <th class=\"num\" style=\"width:140px; color:black\">Amount (SLSH)</th>\r\n      </tr>\r\n    </thead>\r\n    <tbody>\r\n      {% set slsh_total = 0 %}\r\n      {% if doc.shilling_accounts %}\r\n        {% for r in doc.shilling_accounts %}\r\n          {% set slsh_total = slsh_total + (r.amount or 0) %}\r\n          <tr>\r\n            <td>{{ loop.index }}</td>\r\n            <td>{{ r.account or \"\" }}</td>\r\n            <td class=\"num\">{{ frappe.format_value(r.amount or 0, {\"fieldtype\":\"Float\"}) }}</td>\r\n          </tr>\r\n        {% endfor %}\r\n      {% else %}\r\n        <tr><td colspan=\"3\" style=\"text-align:center;color:#777;\">No Shilling rows</td></tr>\r\n      {% endif %}\r\n    </tbody>\r\n  </table>\r\n\r\n  <div class=\"totals\">\r\n    <table>\r\n      <tr>\r\n        <td><b>Total USD</b></td>\r\n        <td class=\"num\">\r\n          {{ frappe.format_value(doc.total, {\"fieldtype\":\"Currency\", \"options\":\"USD\"}) }}\r\n        </td>\r\n      </tr>\r\n      <tr>\r\n        <td><b>Total Shilling</b></td>\r\n        <td class=\"num\">\r\n          {{ frappe.format_value(doc.total_shilling, {\"fieldtype\":\"Float\"}) }}\r\n        </td>\r\n      </tr>\r\n      {% if doc.account %}\r\n      <tr>\r\n        <td><b>Account</b></td>\r\n        <td class=\"num\">{{ doc.account }}</td>\r\n      </tr>\r\n      {% endif %}\r\n      {% if doc.balance is not none %}\r\n      <tr>\r\n        <td><b>Account Balance</b></td>\r\n        <td class=\"num\">\r\n          {{ frappe.format_value(doc.balance, {\"fieldtype\":\"Currency\", \"options\":\"USD\"}) }}\r\n        </td>\r\n      </tr>\r\n      {% endif %}\r\n    </table>\r\n  </div>\r\n\r\n  <div style=\"margin-top:12px;\">\r\n    <b>Comment / Notes</b>\r\n    <div class=\"note\">{{ doc.details or \"\" }}</div>\r\n  </div>\r\n\r\n  <div class=\"sign\">\r\n    <div class=\"box\">Prepared By: {{ doc.user_name or \"\" }}</div>\r\n    <div class=\"box\">Checked By:</div>\r\n    <div class=\"box\">Approved By:</div>\r\n  </div>\r\n\r\n  <div class=\"small\">\r\n    Printed on: {{ frappe.utils.now_datetime() }}\r\n  </div>\r\n\r\n</div>\r\n</section>",
