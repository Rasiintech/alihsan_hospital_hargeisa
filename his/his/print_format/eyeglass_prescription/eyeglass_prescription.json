 "css": ".mx{\n    width: 700px;\n    margin: 0 auto;\n}\n\n.table1{\n    width: 100%;\n}\n\n .table1, tr, th, td {\n  border: 1px solid black;\n  border-collapse: collapse;\n}\n\n        .info-table {\n            width: 100%;\n            border-collapse: collapse;\n            margin-top: 30px;\n            font-size: 18px;\n        }\n        .info-table th, .info-table td {\n            border: 1px solid black;\n            padding: 8px;\n            text-align: left;\n        }",
 "custom_format": 1,
 "default_print_language": "en",
 "disabled": 0,
 "doc_type": "EyeGlass Prescription",
 "docstatus": 0,
 "doctype": "Print Format",
 "font_size": 14,
 "html": "<main class=\"mx\">\r\n        <header style=\"display: flex; align-items: center; gap: 50px; border-bottom: 2px solid black;\" class=\"mx\">\r\n        <div>\r\n           {{ letter_head }}\r\n        </div>\r\n    </header>\r\n    \r\n    <h1 style=\"text-decoration: underline; text-align: center;\">EYE GLASSES PRESCRIPTION</h1>\r\n    \r\n          <div style=\"display: flex; flex-direction: column; gap: 20px; margin-bottom: 20px\">\r\n                 <div>\r\n            <span style=\"font-size: 18px;\"><strong>PID</strong>: <span style=\"color: black; font-size: 18px\">{{doc.patient}}</span></span>\r\n        </div>\r\n                    <div>\r\n            <span style=\"font-size: 18px;\"><strong>Date</strong>: <span style=\"color: black; font-size: 18px\">{{doc.date}}</span></span>\r\n        </div>\r\n        <div>\r\n            <span style=\"font-size: 18px;\"><strong>Name</strong>: <span style=\"color: black; font-size: 18px\">{{doc.patient_name}}</span></span>\r\n        </div>\r\n      </div>\r\n    \r\n    <div>\r\n        <table class=\"table1\">\r\n            <thead>\r\n                <tr>\r\n                    <th style=\"color: black; font-size: 18px\">Lenses material</th>\r\n                    <th style=\"color: black; font-size: 18px\">Lenses advised</th>\r\n                    <th style=\"color: black; font-size: 18px\">Specification</th>\r\n                </tr>\r\n            </thead>\r\n                        <tbody>\r\n                <tr>\r\n                <td style=\"font-size: 18px\">{{doc.lenes_material}}</td>\r\n            <!--Lenses advised-->\r\n                <td style=\"font-size: 18px\">\r\n                    {% if doc.distance or doc.near or doc.bifocal or doc.progressive or doc.sunglass or doc.contac_lenses %}\r\n                        {% if doc.distance %}\r\n                            Distance,\r\n                        {% endif %}\r\n                        {% if doc.near %}\r\n                            Near,\r\n                        {% endif %}\r\n                        {% if doc.bifocal %}\r\n                            Bifocal,\r\n                        {% endif %}\r\n                        {% if doc.progressive %}\r\n                            Progressive,\r\n                            <br>\r\n                        {% endif %}\r\n                        {% if doc.sunglass %}\r\n                            Sunglass,\r\n                        {% endif %}\r\n                        {% if doc.contac_lenses %}\r\n                            Contact lenses\r\n                        {% endif %}\r\n                    {% else %}\r\n                        No lenses advised\r\n                    {% endif %}\r\n                </td>\r\n            <!--Lenses advised-->\r\n                \r\n            <!--specification-->\r\n                    <td style=\"font-size: 18px\">\r\n                        {% if doc.photo_solar or doc.balance or doc.seperate or doc.ar or doc.hc_coating or doc.hmc_coating or doc.polorized_white or doc.white %}\r\n                            {% if doc.photo_solar %}\r\n                                Photo Solar,\r\n                            {% endif %}\r\n                            {% if doc.balance %}\r\n                                Balance,\r\n                            {% endif %}\r\n                            {% if doc.seperate %}\r\n                                Separate,\r\n                            {% endif %}\r\n                            {% if doc.ar %}\r\n                                AR (Blue Cut),\r\n                            {% endif %}\r\n                            {% if doc.hc_coating %}\r\n                                HC Coating,\r\n                                <br>\r\n                            {% endif %}\r\n                            {% if doc.hmc_coating %}\r\n                                HMC Coating,\r\n                            {% endif %}\r\n                            {% if doc.polorized_white %}\r\n                                Polarized White,\r\n                            {% endif %}\r\n                            {% if doc.white %}\r\n                                White\r\n                            {% endif %}\r\n                        {% else %}\r\n                            No specifications\r\n                        {% endif %}\r\n                    </td>\r\n                <!--specification-->\r\n                </tr>\r\n            </tbody>\r\n        </table>\r\n        \r\n    <!--     <table class=\"info-table\">-->\r\n    <!--    <tr>-->\r\n    <!--        <th style=\"color: black\">Tinted</th>-->\r\n    <!--        <td>{{doc.tnted}}</td>-->\r\n    <!--    </tr>-->\r\n    <!--    <tr>-->\r\n    <!--        <th style=\"color: black\">Diameter</th>-->\r\n    <!--        <td>{{doc.diameter}}</td>-->\r\n    <!--    </tr>-->\r\n    <!--</table>-->\r\n    \r\n    <div style=\"display: flex; flex-direction: column; gap: 10px\">\r\n        \r\n        <!--right-->\r\n        <div style=\"width: 100%\">\r\n            <h3>Right Eye</h3>\r\n            <table class=\"table1\" style=\"width: 100%\">\r\n                <thead>\r\n                    <tr>\r\n                        <th style=\"color: black; font-size: 18px;\">UCVA</th>\r\n                        <th style=\"color: black; font-size: 18px;\">Sph</th>\r\n                        <th style=\"color: black; font-size: 18px;\">Cyl</th>\r\n                        <th style=\"color: black; font-size: 18px;\">Axis</th>\r\n                        <th style=\"color: black; font-size: 18px;\">ADD</th>\r\n                        <th style=\"color: black; font-size: 18px;\">PRISMA</th>\r\n                        <th style=\"color: black; font-size: 18px;\">CV/A</th>\r\n                    </tr>\r\n                </thead>\r\n                <tbody>\r\n                {% for d in doc.right_eye %}\r\n                    <tr>\r\n                        <td style=\"font-size: 18px;\">{{d.ucva or \"\"}}</td>\r\n                        <td style=\"font-size: 18px;\">{{d.sph or \"\"}}</td>\r\n                        <td style=\"font-size: 18px;\">{{d.cyl or \"\"}}</td>\r\n                        <td style=\"font-size: 18px;\">{{d.axis or ''}}</td>\r\n                        <td style=\"font-size: 18px;\">{{d.add or ''}}</td>\r\n                        <td style=\"font-size: 18px;\">{{d.prisma or ''}}</td>\r\n                        <td style=\"font-size: 18px;\">{{d.s_va or ''}}</td>\r\n                    </tr>\r\n                \r\n                {% endfor %}\r\n                </tbody>\r\n            </table>\r\n        </div>\r\n        \r\n        <!--left-->\r\n        <div style=\" width: 100%\">\r\n            <h3>Left Eye</h3>\r\n            <table class=\"table1\" style=\"width: 100%\">\r\n                <thead>\r\n                    <tr>\r\n                          <th style=\"color: black; font-size: 18px;\">UCVA</th>\r\n                        <th style=\"color: black; font-size: 18px;\">Sph</th>\r\n                        <th style=\"color: black; font-size: 18px;\">Cyl</th>\r\n                        <th style=\"color: black; font-size: 18px;\">Axis</th>\r\n                        <th style=\"color: black; font-size: 18px;\">ADD</th>\r\n                        <th style=\"color: black; font-size: 18px;\">PRISMA</th>\r\n                        <th style=\"color: black; font-size: 18px;\">CV/A</th>\r\n                    </tr>\r\n                </thead>\r\n                <tbody>\r\n                {% for d in doc.left_eye %}\r\n                    <tr>\r\n                        <td style=\"font-size: 18px;\">{{d.ucva or \"\"}}</td>\r\n                        <td style=\"font-size: 18px;\">{{d.sph or \"\"}}</td>\r\n                        <td style=\"font-size: 18px;\">{{d.cyl or \"\"}}</td>\r\n                        <td style=\"font-size: 18px;\">{{d.axis or ''}}</td>\r\n                        <td style=\"font-size: 18px;\">{{d.add or ''}}</td>\r\n                        <td style=\"font-size: 18px;\">{{d.prisma or ''}}</td>\r\n                        <td style=\"font-size: 18px;\">{{d.s_va or ''}}</td>\r\n                    </tr>\r\n                \r\n                {% endfor %}\r\n                </tbody>\r\n            </table>\r\n        </div>\r\n    </div>\r\n\r\n    </div>\r\n    \r\n    <div style=\"display: flex; flex-direction: column; gap: 5px; font-size: 18px; margin-top: 14px\">\r\n        <span style=\"font-size: 18px\">Distance</span>\r\n        <span style=\"font-size: 18px\"><stron>P.D:</stron> <span style=\"color: black; font-size: 18px\">{{doc.distance_pd or \"\"}}</span></span>\r\n         <span style=\"font-size: 18px\"><stron>Near P.D:</stron> <span style=\"color: black; font-size: 18px\">{{doc.near_pd}}</span></span>\r\n          <span style=\"font-size: 18px\"><stron>Note:</stron> <span style=\"color: black; font-size: 18px\">{{doc.note or \"\"}}</span></span>\r\n    </div>\r\n    \r\n     <div class=\"row\">\r\n          \r\n        <div class=\"col-xs-3 text-left\" style=\"color: black; font-size: 18px\">\r\n         Refered:\r\n        </div>\r\n        {% if doc.practitioner %}\r\n        <div class=\"col-xs-9  text-left value\" style=\"color: black; font-size: 18px\">\r\n         <label style=\"font-size: 18px\">  {{ doc.practitioner }} </label> \r\n        </div>\r\n        {% else %}\r\n\t\t\t{% if doc.practitioner %}\r\n            <div style=\"font-size: 18px\" class=\"col-xs-10  text-left value\">\r\n            {{ doc.practitioner }}\r\n            </div>\r\n\t\t    {% endif %}\r\n        {%- endif -%}\r\n      </div>\r\n      <p style=\"font-size: 18px\">Printed By: {{frappe.db.get_value(\"User\" , doc.owner , \"full_name\")}}</p>\r\n      <!--<span class=\"span\">{{frappe.db.get_value(\"User\" , doc.owner , \"full_name\")}}</span>-->\r\n      <span style=\"color: black; font-size: 18px\"><stron>Signature:</stron> </span>\r\n    \r\n    \r\n</main>",
