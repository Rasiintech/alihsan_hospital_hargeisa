 "html": "<style>\r\n  * {\r\n    margin: 0;\r\n    padding: 0;\r\n    box-sizing: border-box;\r\n  }\r\n\r\n  body {\r\n    font-family: Arial, sans-serif;\r\n    font-size: 11px;\r\n    color: #000;\r\n    background: #fff;\r\n    margin: 0;\r\n    padding: 0;\r\n  }\r\n\r\n  .invoice-page {\r\n    width: 100%;\r\n    max-width: 700px;\r\n    margin: 0 auto;\r\n    padding: 40px 0;\r\n  }\r\n\r\n  /* TABLE LINE HEIGHT */\r\n  .invoice-page table,\r\n  .invoice-page tr,\r\n  .invoice-page th,\r\n  .invoice-page td {\r\n    line-height: 0.5;\r\n  }\r\n\r\n  /* \u2500\u2500 TOP HEADER ROW \u2500\u2500 */\r\n  .header {\r\n    display: flex;\r\n    justify-content: space-between;\r\n    align-items: center;\r\n    margin-bottom: 10px;\r\n  }\r\n\r\n  .logo {\r\n    display: flex;\r\n    align-items: center;\r\n    gap: 10px;\r\n  }\r\n\r\n  .logo-icon {\r\n    width: 54px;\r\n    height: 54px;\r\n    background: #E8920A;\r\n    clip-path: polygon(50% 0%, 85% 15%, 100% 50%, 85% 85%, 50% 100%, 15% 85%, 0% 50%, 15% 15%);\r\n    overflow: hidden;\r\n  }\r\n\r\n  .logo-icon img {\r\n    width: 100%;\r\n    height: 100%;\r\n    object-fit: cover;\r\n  }\r\n\r\n  .logo-text .name {\r\n    font-size: 24px;\r\n    font-weight: 900;\r\n    color: #1C3664;\r\n    letter-spacing: 1px;\r\n    line-height: 1;\r\n  }\r\n\r\n  .logo-text .sub {\r\n    font-size: 9px;\r\n    font-weight: 700;\r\n    color: #E8920A;\r\n    letter-spacing: 2.5px;\r\n    line-height: 1;\r\n  }\r\n\r\n  .invoice-word {\r\n    font-size: 40px;\r\n    font-weight: 900;\r\n    color: #E8920A;\r\n    letter-spacing: 2px;\r\n    line-height: 1;\r\n  }\r\n\r\n  /* \u2500\u2500 ADDRESS / INVOICE META \u2500\u2500 */\r\n  .meta-row {\r\n    display: flex;\r\n    justify-content: space-between;\r\n    align-items: flex-start;\r\n    margin-bottom: 18px;\r\n    gap: 20px;\r\n  }\r\n\r\n  .address {\r\n    font-size: 10px;\r\n    line-height: 1.2;\r\n    color: #111;\r\n  }\r\n\r\n  .info-table {\r\n    border-collapse: collapse;\r\n    margin-top: 2px;\r\n  }\r\n\r\n  .info-table tr td {\r\n    font-size: 10px;\r\n    padding: 1px 0;\r\n    line-height: 0.5;\r\n  }\r\n\r\n  .info-table tr td:first-child {\r\n    font-weight: 700;\r\n    text-align: right;\r\n    padding-right: 6px;\r\n    white-space: nowrap;\r\n  }\r\n\r\n  .info-table tr td:last-child {\r\n    border: 1px solid #aaa;\r\n    min-width: 110px;\r\n    text-align: center;\r\n    padding: 1px 6px;\r\n  }\r\n\r\n  /* \u2500\u2500 PAYMENT TO \u2500\u2500 */\r\n  .payment-label {\r\n    display: inline-block;\r\n    background: #1C3664;\r\n    color: #fff;\r\n    font-weight: 700;\r\n    font-size: 10.5px;\r\n    padding: 4px 10px;\r\n    width: 340px;\r\n    margin-bottom: 5px;\r\n    line-height: 1;\r\n  }\r\n\r\n  .payment-body {\r\n    font-size: 10px;\r\n    line-height: 1.2;\r\n    margin-bottom: 22px;\r\n    padding-left: 2px;\r\n  }\r\n\r\n  /* \u2500\u2500 ITEMS TABLE \u2500\u2500 */\r\n  .items-table {\r\n    width: 100%;\r\n    border-collapse: collapse;\r\n    border: 1px solid #aaa;\r\n    line-height: 0.5;\r\n  }\r\n\r\n  .items-table thead tr th {\r\n    background: #1C3664;\r\n    color: #fff;\r\n    font-size: 11px;\r\n    font-weight: 700;\r\n    padding: 7px 10px;\r\n    letter-spacing: 0.5px;\r\n    line-height: 0.5;\r\n  }\r\n\r\n  .items-table thead tr th.col-desc {\r\n    text-align: left;\r\n    width: 75%;\r\n  }\r\n\r\n  .items-table thead tr th.col-price {\r\n    text-align: center;\r\n    width: 12%;\r\n  }\r\n\r\n  .items-table thead tr th.col-amount {\r\n    text-align: center;\r\n    width: 13%;\r\n  }\r\n\r\n  .items-table tbody tr td {\r\n    padding: 5px 10px;\r\n    font-size: 10px;\r\n    border-right: 1px solid #aaa;\r\n    height: 20px;\r\n    line-height: 0.5;\r\n  }\r\n\r\n  .items-table tbody tr td:last-child {\r\n    border-right: none;\r\n  }\r\n\r\n  .items-table tbody tr td.col-price,\r\n  .items-table tbody tr td.col-amount {\r\n    text-align: right;\r\n  }\r\n\r\n  .items-table tbody tr:nth-child(odd) td {\r\n    background: #fff;\r\n  }\r\n\r\n  .items-table tbody tr:nth-child(even) td {\r\n    background: #dce6f1;\r\n  }\r\n\r\n  /* \u2500\u2500 BOTTOM SECTION \u2500\u2500 */\r\n  .bottom {\r\n    display: flex;\r\n    justify-content: space-between;\r\n    align-items: stretch;\r\n    border: 1px solid #aaa;\r\n    border-top: none;\r\n  }\r\n\r\n  .comments {\r\n    width: 62%;\r\n    border-right: 1px solid #aaa;\r\n  }\r\n\r\n  .comments-label {\r\n    background: #E8920A;\r\n    color: #fff;\r\n    font-weight: 700;\r\n    font-size: 10px;\r\n    padding: 4px 8px;\r\n    letter-spacing: 0.5px;\r\n    line-height: 1;\r\n  }\r\n\r\n  .comments-body {\r\n    padding: 6px 8px;\r\n    font-size: 10px;\r\n    line-height: 1.2;\r\n  }\r\n\r\n  .comments-note {\r\n    font-size: 9.5px;\r\n    color: #111;\r\n    margin-top: 8px;\r\n    border-top: 1px solid #ddd;\r\n    padding-top: 6px;\r\n    text-align: center;\r\n    line-height: 1.2;\r\n  }\r\n\r\n  .totals-side {\r\n    width: 38%;\r\n  }\r\n\r\n  .totals-table {\r\n    width: 100%;\r\n    border-collapse: collapse;\r\n    line-height: 0.5;\r\n  }\r\n\r\n  .totals-table td {\r\n    font-size: 10px;\r\n    padding: 3px 8px;\r\n    border-bottom: 1px solid #aaa;\r\n    line-height: 0.5;\r\n  }\r\n\r\n  .totals-table td:first-child {\r\n    font-weight: 400;\r\n  }\r\n\r\n  .totals-table td:nth-child(2) {\r\n    text-align: left;\r\n    width: 18px;\r\n    border-left: 1px solid #aaa;\r\n  }\r\n\r\n  .totals-table td:last-child {\r\n    text-align: right;\r\n    border-left: 1px solid #aaa;\r\n    min-width: 70px;\r\n  }\r\n\r\n  .totals-table tr.total-row td {\r\n    font-weight: 900;\r\n    font-size: 11px;\r\n    line-height: 0.5;\r\n  }\r\n\r\n  .payable-note {\r\n    text-align: center;\r\n    font-size: 10px;\r\n    margin-top: 8px;\r\n    line-height: 1.2;\r\n    padding: 0 6px 6px 6px;\r\n  }\r\n\r\n  .payable-note strong {\r\n    font-size: 11px;\r\n    font-weight: 900;\r\n  }\r\n\r\n  /* \u2500\u2500 FOOTER \u2500\u2500 */\r\n  .footer {\r\n    margin-top: 30px;\r\n    text-align: center;\r\n    font-size: 10px;\r\n    line-height: 1.2;\r\n  }\r\n\r\n  .footer .thankyou {\r\n    font-style: italic;\r\n    font-weight: 700;\r\n    font-size: 11px;\r\n  }\r\n\r\n  /* \u2500\u2500 PRINT SETTINGS FOR ALL PAGE SIZES \u2500\u2500 */\r\n  @page {\r\n    margin: 10mm;\r\n  }\r\n\r\n  @media print {\r\n    html,\r\n    body {\r\n      width: auto;\r\n      height: auto;\r\n      margin: 0;\r\n      padding: 0;\r\n      background: #fff;\r\n    }\r\n\r\n    .invoice-page {\r\n      width: 100%;\r\n      max-width: 100%;\r\n      margin: 0 auto;\r\n      padding: 0;\r\n    }\r\n\r\n    .header,\r\n    .meta-row,\r\n    .bottom {\r\n      break-inside: avoid;\r\n      page-break-inside: avoid;\r\n    }\r\n\r\n    .items-table {\r\n      page-break-inside: auto;\r\n    }\r\n\r\n    .items-table tr {\r\n      page-break-inside: avoid;\r\n      page-break-after: auto;\r\n    }\r\n  }\r\n\r\n  /* \u2500\u2500 SMALL PRINT WIDTH SUPPORT: A5 / COMPACT PAPER \u2500\u2500 */\r\n  @media print and (max-width: 600px) {\r\n    body {\r\n      font-size: 9px;\r\n    }\r\n\r\n    .header {\r\n      margin-bottom: 8px;\r\n    }\r\n\r\n    .logo-icon {\r\n      width: 42px;\r\n      height: 42px;\r\n    }\r\n\r\n    .logo-text .name {\r\n      font-size: 19px;\r\n    }\r\n\r\n    .logo-text .sub {\r\n      font-size: 7px;\r\n      letter-spacing: 1.7px;\r\n    }\r\n\r\n    .invoice-word {\r\n      font-size: 30px;\r\n      letter-spacing: 1px;\r\n    }\r\n\r\n    .meta-row {\r\n      margin-bottom: 12px;\r\n      gap: 10px;\r\n    }\r\n\r\n    .address,\r\n    .info-table tr td,\r\n    .payment-body,\r\n    .items-table tbody tr td,\r\n    .totals-table td,\r\n    .comments-body,\r\n    .comments-note,\r\n    .footer {\r\n      font-size: 8.5px;\r\n    }\r\n\r\n    .payment-label {\r\n      width: 100%;\r\n      font-size: 9px;\r\n      padding: 3px 8px;\r\n    }\r\n\r\n    .payment-body {\r\n      margin-bottom: 14px;\r\n    }\r\n\r\n    .items-table thead tr th {\r\n      font-size: 9px;\r\n      padding: 5px 6px;\r\n      line-height: 0.5;\r\n    }\r\n\r\n    .items-table tbody tr td {\r\n      padding: 4px 6px;\r\n      height: 17px;\r\n      line-height: 0.5;\r\n    }\r\n\r\n    .comments-label {\r\n      font-size: 8.5px;\r\n      padding: 3px 6px;\r\n    }\r\n\r\n    .totals-table td {\r\n      padding: 2px 5px;\r\n      line-height: 0.5;\r\n    }\r\n\r\n    .totals-table tr.total-row td {\r\n      font-size: 9px;\r\n    }\r\n\r\n    .payable-note {\r\n      font-size: 8.5px;\r\n    }\r\n\r\n    .payable-note strong {\r\n      font-size: 9px;\r\n    }\r\n\r\n    .footer {\r\n      margin-top: 18px;\r\n      line-height: 1.2;\r\n    }\r\n\r\n    .footer .thankyou {\r\n      font-size: 9px;\r\n    }\r\n  }\r\n</style>\r\n</head>\r\n\r\n<body>\r\n\r\n<main class=\"invoice-page\">\r\n\r\n  <!-- TOP HEADER -->\r\n  <div class=\"header\">\r\n    <div class=\"logo\">\r\n      <div class=\"logo-icon\">\r\n        <img src=\"/files/alihsanhospitalso_logo.jfif\">\r\n      </div>\r\n      <div class=\"logo-text\">\r\n        <div class=\"name\">AL IHSAN</div>\r\n        <div class=\"sub\">SPECIALIST HOSPITAL</div>\r\n      </div>\r\n    </div>\r\n    <div class=\"invoice-word\">INVOICE</div>\r\n  </div>\r\n\r\n  <!-- ADDRESS + INVOICE META -->\r\n  <div class=\"meta-row\">\r\n    <div class=\"address\">\r\n      Beerta Xuriyada, 26 June District<br>\r\n      Hargeisa Somaliland<br>\r\n      Phone:+252634560557,+252634036735<br>\r\n      Website: www.alihsanhospitals.com\r\n    </div>\r\n\r\n    <div>\r\n      <table class=\"info-table\">\r\n        <tr>\r\n          <td>DATE</td>\r\n          <td>{{ doc.posting_date }}</td>\r\n        </tr>\r\n        <tr>\r\n          <td>INVOICE #</td>\r\n          <td>{{ doc.name.split(\"-\")[3] }}</td>\r\n        </tr>\r\n        <tr>\r\n          <td>DUE DATE</td>\r\n          <td>{{ doc.posting_date }}</td>\r\n        </tr>\r\n      </table>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- PAYMENT TO -->\r\n  <div class=\"payment-label\">Payment to</div>\r\n  <div class=\"payment-body\">\r\n    ZAAD MERCHANT 481926<br>\r\n    EDAHAB MERCHANT 755301<br>\r\n  </div>\r\n\r\n  <!-- ITEMS TABLE -->\r\n  <table class=\"items-table\">\r\n    <thead>\r\n      <tr>\r\n        <th class=\"col-desc\">DESCRIPTION</th>\r\n        <th class=\"col-price\">Price</th>\r\n        <th class=\"col-amount\">AMOUNT</th>\r\n      </tr>\r\n    </thead>\r\n\r\n    <tbody>\r\n      {% for item in doc.items %}\r\n      <tr>\r\n        <td class=\"col-desc\">\r\n          {{ item.item_name or item.description or item.item_code }}\r\n        </td>\r\n        <td class=\"col-price\">\r\n          {{ item.get_formatted(\"rate\") }}\r\n        </td>\r\n        <td class=\"col-amount\">\r\n          {{ item.get_formatted(\"amount\") }}\r\n        </td>\r\n      </tr>\r\n      {% endfor %}\r\n\r\n      {% if doc.items|length < 12 %}\r\n        {% for i in range(12 - doc.items|length) %}\r\n        <tr>\r\n          <td class=\"col-desc\">&nbsp;</td>\r\n          <td class=\"col-price\">&nbsp;</td>\r\n          <td class=\"col-amount\">&nbsp;</td>\r\n        </tr>\r\n        {% endfor %}\r\n      {% endif %}\r\n    </tbody>\r\n  </table>\r\n\r\n  <!-- BOTTOM: COMMENTS + TOTALS -->\r\n  <div class=\"bottom\">\r\n\r\n    <div class=\"comments\">\r\n      <div class=\"comments-label\">OTHER COMMENTS</div>\r\n\r\n      <div class=\"comments-body\">\r\n        1. Total payment due in 17 days<br>\r\n        2. Please include the invoice number on your check<br>\r\n\r\n        <div class=\"comments-note\">\r\n          The services were provided by Al Ihsan Specialist Hospital, while billing and payment collection are handled by {{ doc.customer }}. Payment is payable to {{ doc.customer }}.\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"totals-side\">\r\n      <table class=\"totals-table\">\r\n        <tr>\r\n          <td>Subtotal</td>\r\n          <td>$</td>\r\n          <td>{{ doc.total }}</td>\r\n        </tr>\r\n        <tr>\r\n          <td>Discounts</td>\r\n          <td>$</td>\r\n          <td>{{ doc.discount_amount }}</td>\r\n        </tr>\r\n        <tr>\r\n          <td>Other</td>\r\n          <td></td>\r\n          <td>-</td>\r\n        </tr>\r\n        <tr class=\"total-row\">\r\n          <td>TOTAL</td>\r\n          <td>$</td>\r\n          <td>{{ doc.grand_total }}</td>\r\n        </tr>\r\n      </table>\r\n\r\n      <div class=\"payable-note\">\r\n        Make all checks payable to<br>\r\n        <strong>{{ doc.customer }}</strong>\r\n      </div>\r\n    </div>\r\n\r\n  </div>\r\n\r\n  <!-- FOOTER -->\r\n  <div class=\"footer\">\r\n    If you have any questions about this invoice, please contact<br>\r\n    Phone:+252634560557,+252634036735<br>\r\n    <span class=\"thankyou\">Thank You For Your Business!</span>\r\n  </div>\r\n\r\n</main>\r\n\r\n</body>",
