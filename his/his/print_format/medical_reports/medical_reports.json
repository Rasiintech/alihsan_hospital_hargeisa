 "html": "<style>\nhtml {\n    font-size: 100%;\n    box-sizing: border-box;\n}\n\n*,\n*::before,\n*::after {\n    box-sizing: inherit;\n}\n\nbody {\n    padding: 0;\n    margin: 0;\n    font-family: \"Times New Roman\", Times, serif;\n    font-size: .875rem;\n    font-weight: 300;\n    color: #000;\n}\n\nh1,\nh2,\nh3 {\n    font-weight: 300;\n    color: #000;\n    margin-top: 0;\n    font-family: \"Times New Roman\", Times, serif;\n}\n\np {\n    margin-top: 0;\n}\n\na,\na:visited,\na:hover {\n    text-decoration: none;\n}\n\n.marginX {\n    margin-inline: 50px;\n}\n\n.header {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    margin-block-start: 19px;\n    justify-content: center;\n    padding-bottom: 8px;\n}\n\n.header__top {\n    display: flex;\n    align-items: center;\n    gap: 9px;\n}\n\n.header__logo {\n    width: 70px;\n    height: 70px;\n    object-fit: contain;\n    padding-bottom: 9px;\n}\n\n.header__title {\n    font-weight: bold;\n    text-transform: uppercase;\n}\n\n.header__phone,\n.header__gmail,\n.header__country {\n    font-size: 1.125rem;\n    text-align: center;\n}\n\n.banner {\n    display: flex;\n    flex-direction: column;\n    margin-block-start: 10px;\n    gap: 8px;\n}\n\n.banner__title {\n    text-align: center;\n    font-weight: bold;\n    font-size: 1.0rem;\n    text-transform: uppercase;\n}\n\n.banner__midd,\n.banner__bottom {\n    display: flex;\n    align-items: center;\n    gap: 18px;\n}\n\n.table {\n    border-collapse: collapse;\n    border-top: 1px solid #000;\n    border-left: 1px solid #000;\n    border-right: 1px solid #000;\n    margin-block-start: 15px;\n}\n\n.table__tb thead tr th {\n    border-left: 1px solid #000 !important;\n    text-align: left;\n}\n\n.table__tb tbody tr td {\n    text-align: left;\n    border-bottom: 1px solid #000;\n}\n\n.footer {\n    display: flex;\n    flex-direction: column;\n    margin-block-start: 30px;\n    color: #000;\n    gap: 46px;\n}\n\n.footer__authSig {\n    font-weight: bold;\n    text-transform: uppercase;\n}\n\n.footer__line {\n    background: #000;\n    height: 1px;\n    width: 100%;\n}\n</style>\n\n<header class=\"header marginX\">\n    {% if letter_head  -%}\n    <div class=\"letter-head text-center\">{{ letter_head }}</div>\n    {% endif %}\n    \n    <h2 style=\"text-align: center; font-weight: bold;\">To Whom It May Concern</h2>\n</header>\n\n<section class=\"banner marginX\" style=\"margin-top: 5px\">\n    <div class=\"banner__midd\">\n        <h4 class=\"banner__client\">PID:</h4>\n        <h4 class=\"banner__clientname\">{{ doc.patient }}</h4>\n        <h4 class=\"banner__client\">Patient:</h4>\n        <h4 class=\"banner__clientname\">{{ doc.patient_name }}</h4>\n        <h4 class=\"banner__client\">Age:</h4>\n        <h4 class=\"banner__clientname\">{{ doc.age }}</h4>\n        <h4 class=\"banner__client\">Gender:</h4>\n        <h4 class=\"banner__clientname\">{{ doc.sex }}</h4>\n    </div>\n\n    <div class=\"banner__bottom\">\n        <h4 class=\"banner__client\" style=\"line-height: 1;\"><b>Diagnosis</b>: \n            {{ doc.diagnosis or \"\" }}\n        </h4>\n    </div>\n      \n    <div class=\"banner__bottom\">\n        <h4 class=\"banner__client\" style=\"line-height: 1;\"><b>Treatment</b>: \n            {{ doc.treatment or \"\" }}\n        </h4>\n    </div>\n\n    <div class=\"banner__bottom\" style=\"margin-top: 1.5;\">\n        <h4 class=\"banner__client\" style=\"line-height: 1.5;\"><b>Recommendation</b>: \n            {{ doc.recommendation or \"\" }}\n        </h4>\n    </div>\n\n    <div class=\"banner__midd\">\n        <h4 class=\"banner__client\">Date:</h4>\n        {% if doc.date %}\n        <h4 class=\"banner__clientname\">{{ doc.date }}</h4>\n        {% else %}\n        <h4 class=\"banner__clientname\">_________________</h4>\n        {% endif %}\n    </div>\n</section>\n\n<footer class=\"footer marginX\">\n    <div class=\"footer__bottom\">\n        <div class=\"footer__left\">\n            <span class=\"footer__authSig\">{{ doc.consultant }}:________________________________</span>\n            <!--<div class=\"footer__line\"></div>-->\n        </div>\n    </div>\n</footer>\n",
